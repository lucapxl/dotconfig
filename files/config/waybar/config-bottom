{
    "position": "bottom",
    "height": 36,
    "spacing": 0,
    "exclusive": true,
    "passthrough": false,
    "modules-left": [
        "custom/rofi",
        "wlr/taskbar"
    ],
    "modules-center": [],
    "modules-right": [
        "custom/hostname"
    ],
    "custom/rofi": {
        "format": " ",
        "on-click": "~/.config/scripts/rofi",
        "tooltip": false
    },
    "wlr/taskbar": {
        "all-outputs": false,
        "format": "{icon} {name} - {title}",
        "icon-size": 16,
        "icon-theme": "Papirus",
        "tooltip-format": "{name}\n{title}",
        "on-click": "activate",
        "markup": false,
        "rewrite": {
            "(.{30}).+": "$1…"
        },
        "sort-by-app-id": true
    },
    "custom/hostname": {
        "exec": "hostname",
        "interval": 3600,
        "format": " {}",
        "tooltip": false
    }
}
