
{
    "position": "top",
    "height": 36, 
    "spacing": 0,
    "modules-left": [
        "ext/workspaces",
	      "idle_inhibitor"
    ],
    "modules-center": [
	      "clock"
    ],
    "modules-right": [
        "tray",
        "network#wg",
        "network#eth",
        "network#wifi",
        "custom/labwclang",
        "pulseaudio",
        "battery",
        "custom/powerctl"
    ],
    "ext/workspaces": {
        "all-outputs": true,
        "format": "{name}",
        "sort-by-id": true,
	      "on-click": "activate"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
