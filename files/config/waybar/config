        "icon-size": 16
    },
    "clock": {
        "format": "{:%H:%M}",
        "tooltip-format": "{:%d/%m/%Y}"
    },
    "battery": {
        "interval": 10,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}",
        "format-warning": "{capacity}% {icon}",
        "format-critical": "{capacity}% {icon}",
        "format-charging": "{capacity}% {icon} ´âž",
        "format-full": "{icon}",
