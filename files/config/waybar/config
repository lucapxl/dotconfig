{
    "position": "top",
    "height": 36, 
    "spacing": 0,
    "modules-left": [
        "ext/workspaces",
        "custom/taskbar-toggle",
	    "idle_inhibitor"
    ],
    "modules-center": [
	      "clock"
    ],
    "modules-right": [
        "tray",
        "custom/wg",
        "network#eth",
        "network#wifi",
        "custom/labwclang",
        "pulseaudio",
        "battery",
        "custom/powerctl"
    ],
    "ext/workspaces": {
        "all-outputs": true,
        "format": "{name}",
        "sort-by-id": true,
	      "on-click": "activate"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "´â┤",
            "deactivated": "´â┤"
        }
    },
    "tray": {
        "spacing": 20,
        "icon-size": 16
    },
    "clock": {
        "format": "{:%H:%M}",
        "tooltip-format": "{:%d/%m/%Y}"
    },
    "battery": {
        "interval": 10,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}",
        "format-warning": "{capacity}% {icon}",
        "format-critical": "{capacity}% {icon}",
        "format-charging": "{capacity}% {icon} ´çŽ",
        "format-full": "{icon}",
        "format-plugged": "{icon} ´çŽ",
        "tooltip-format": "´ëÇ: {capacity}%\n{timeTo}",
        "format-alt": "{capacity}% {timeTo}",
        "format-icons": ["´ëä", "´ëâ", "´ëü", "´ëÇ"]
    },
    "network#eth": {
        "interface": "enp*",
        "interval": 5,
        "format": "ţ╝ë",
        "format-disconnected": "",
        "tooltip-format": "<b>IP:</b> {ipaddr}\n<b>GW:</b> {gwaddr}\n<b>IF:</b> {ifname}",
        "tooltip-format-disconnected": "",
        "on-click": "foot -a nmtui bash -c 'sleep 0.1 && nmtui'"
    },
    "network#wifi": {
        "interface": "wlp*",
        "interval": 5,
        "format-wifi": "{icon} ",
        "format-icons": ["ˇ░Ą»", "ˇ░Ąč", "ˇ░Ąó", "ˇ░Ąą", "ˇ░ĄĘ"],
        "format-disconnected": "ˇ░Ą« ",
        "tooltip-format-wifi": "<b>SSID:</b> {essid}\n<b>Signal:</b> {signalStrength}%\n<b>Freq:</b> {frequency}\n\n<b>IP:</b> {ipaddr}\n<b>GW:</b> {gwaddr}\n<b>IF:</b> {ifname}",
        "tooltip-format-disconnected": "click to open <b>nmtui</b>",
        "on-click": "foot -a nmtui bash -c 'sleep 0.1 && nmtui'"
    },
    "custom/wg": {
        "exec": "~/.config/scripts/wg-status 'Alpeax Cloud'",
        "return-type": "json",
        "interval": 5,
        "on-click": "~/.config/scripts/network-helper toggle 'Alpeax Cloud'",
        "tooltip": true
    },
    "pulseaudio": {
        "format": "{icon}",
        "tooltip-format": "Volume: {volume}%\nDevice: {desc}",
        "format-bluetooth": "{icon}",
        "format-muted": "ţ╗Ę",
        "format-source": "",
        "scroll-step": 5,
        "format-icons": {
            "default": ["´ÇŽ","´Çž","´ÇĘ"]
        },
        "on-click": "pavucontrol"
    },
    "custom/powerctl": {
        "format": "ÔĆ╗",
        "on-click": "~/.config/scripts/powermenu",
        "tooltip": false
    },
    "custom/labwclang": {
        "exec": "~/.config/scripts/labwc-keyboardlang-helper status",
        "format": "{}",
        "interval": 1,
        "tooltip-format": "Press Alt+Shift to switch between keyboard layouts"
    },
    "custom/taskbar-toggle": {
        "format": "´őĺ",
        "exec": "~/.config/scripts/taskbar-toggle status",
        "return-type": "json",
        "interval": 2,
        "on-click": "~/.config/scripts/taskbar-toggle toggle",
        "tooltip": true
    }
}

